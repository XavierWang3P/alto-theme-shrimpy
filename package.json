{
    "name": "alto-shrimpy",
    "description": "A Ghost theme",
    "version": "1.1.1",
    "private": true,
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/XavierWang3P/alto-theme-shrimpy.git"
    },
    "author": {
        "name": "Ghost Foundation",
        "email": "hello@ghost.org",
        "url": "https://ghost.org"
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "docs": "https://alto.ghost.io/about/",
    "config": {
        "posts_per_page": 5,
        "image_sizes": {
            "xs": {
                "width": 150
            },
            "s": {
                "width": 400
            },
            "m": {
                "width": 750
            },
            "l": {
                "width": 960
            },
            "xl": {
                "width": 1140
            },
            "xxl": {
                "width": 1920
            }
        },
        "card_assets": true,
        "custom": {
            "navigation_layout": {
                "type": "select",
                "options": [
                    "Logo on the left",
                    "Logo in the middle",
                    "Stacked"
                ],
                "default": "Logo on the left"
            },
            "title_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Modern sans-serif"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Modern sans-serif"
            },
            "color_scheme": {
                "type": "select",
                "options": [
                    "Light",
                    "Dark"
                ],
                "default": "Light"
            },
            "accent_color": {
                "type": "color",
                "default": "#ffadc8",
                "group": "homepage"
            },
            "decoration_color": {
                "type": "color",
                "default": "#ffd682",
                "group": "homepage"
            },
            "background_color": {
                "type": "color",
                "default": "#fff6e6",
                "group": "homepage"
            },
            "boxes_background_color": {
                "type": "color",
                "default": "#fff0d3",
                "group": "homepage"
            },
            "boxes_border_color": {
                "type": "color",
                "default": "#ffebc4",
                "group": "homepage"
            },
            "general_border_color": {
                "type": "color",
                "default": "#707070",
                "group": "homepage"
            },
            "white_logo_for_dark_mode": {
                "type": "image"
            },
            "show_featured_posts": {
                "type": "boolean",
                "default": true,
                "group": "homepage"
            },
            "show_author": {
                "type": "boolean",
                "default": true,
                "group": "post"
            },
            "show_related_posts": {
                "type": "boolean",
                "default": true,
                "group": "post"
            }
        }
    },
    "scripts": {
        "dev": "gulp",
        "test": "gscan .",
        "zip": "gulp zip"
    },
    "packageManager": "pnpm@11.11.0",
    "devDependencies": {
        "@tryghost/shared-theme-assets": "2.7.1",
        "@tryghost/theme-translations": "^0.0.9",
        "autoprefixer": "10.5.2",
        "beeper": "2.1.0",
        "cssnano": "8.0.2",
        "gscan": "6.4.1",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.16",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4"
    }
}
