<!DOCTYPE html>
<html lang="{{@site.locale}}"{{#match @custom.color_scheme "Dark"}} class="dark-mode is-default-dark"{{/match}}>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title page=(t " (Page %)")}}</title>
    <script>
        (function () {
            try {
                var storedTheme = localStorage.getItem('alto-theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

                if (storedTheme === 'dark' || (!storedTheme && prefersDark)) {
                    document.documentElement.classList.add('dark-mode');
                } else if (storedTheme === 'light') {
                    document.documentElement.classList.remove('dark-mode');
                }
            } catch (error) {}
        })();
    </script>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <style>
        :root {
            {{#if @custom.accent_color}}
            --ghost-accent-color: {{@custom.accent_color}};
            --primary-color: {{@custom.accent_color}};
            --coral-color: {{@custom.accent_color}};
            {{/if}}
            {{#if @custom.decoration_color}}
            --yellow-color: {{@custom.decoration_color}};
            {{/if}}
            {{#if @custom.background_color}}
            --color-white: {{@custom.background_color}};
            --white-color: {{@custom.background_color}};
            {{/if}}
            {{#if @custom.boxes_background_color}}
            --color-lighter-gray: {{@custom.boxes_background_color}};
            --light-gray-color: {{@custom.boxes_background_color}};
            {{/if}}
            {{#if @custom.boxes_border_color}}
            --color-light-gray: {{@custom.boxes_border_color}};
            --mid-gray-color: {{@custom.boxes_border_color}};
            {{/if}}
            {{#if @custom.general_border_color}}
            --border-color: {{@custom.general_border_color}};
            {{/if}}
        }
    </style>

    {{ghost_head}}
</head>

<body class="{{body_class}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}" data-more-label="{{t "More"}}">
<div class="site">
    <div class="site-hero-doodles" aria-hidden="true">
        <span class="site-doodle site-doodle-hash site-doodle-hash-a">
            <span></span><span></span><span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-ring site-doodle-ring-a"></span>
        <span class="site-doodle site-doodle-lines site-doodle-lines-a"></span>
        <span class="site-doodle site-doodle-chip site-doodle-chip-a">HELLO</span>
        <span class="site-doodle site-doodle-spark site-doodle-spark-a">
            <span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-pills site-doodle-pills-a">
            <span></span><span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-dots site-doodle-dots-a">
            <span></span><span></span><span></span><span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-bubble site-doodle-bubble-a">IDEA</span>
        <span class="site-doodle site-doodle-hash site-doodle-hash-b">
            <span></span><span></span><span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-ring site-doodle-ring-b"></span>
        <span class="site-doodle site-doodle-lines site-doodle-lines-b"></span>
        <span class="site-doodle site-doodle-chip site-doodle-chip-b">NOTE</span>
        <span class="site-doodle site-doodle-spark site-doodle-spark-b">
            <span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-pill site-doodle-pill-a"></span>
        <span class="site-doodle site-doodle-dots site-doodle-dots-b">
            <span></span><span></span><span></span><span></span><span></span>
        </span>
        <span class="site-doodle site-doodle-bubble site-doodle-bubble-b">WOW</span>
    </div>

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}" decoding="async">
                            {{#if @custom.white_logo_for_dark_mode}}
                                <img src="{{img_url @custom.white_logo_for_dark_mode}}" alt="{{@site.title}}" decoding="async">
                            {{/if}}
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>
                </div>
                <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                <button class="theme-toggle theme-toggle-mobile" type="button" aria-label="Toggle dark mode" aria-pressed="false" data-theme-toggle>
                    <span class="toggle-track" aria-hidden="true">
                        <span class="toggle-sun">{{> "icons/sun"}}</span>
                        <span class="toggle-moon">{{> "icons/moon"}}</span>
                        <span class="toggle-thumb"></span>
                    </span>
                </button>
                <button class="gh-burger" aria-label="{{t "Toggle menu"}}"></button>
            </div>

            <nav class="gh-head-menu">
                {{navigation}}
                {{#unless @site.members_enabled}}
                    {{#match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                {{#unless @site.members_enabled}}
                    {{^match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                {{else}}
                    <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    <div class="gh-head-members">
                        {{#unless @member}}
                            {{#unless @site.members_invite_only}}
                                <a class="gh-head-link" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                            {{else}}
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">{{t "Account"}}</a>
                        {{/unless}}
                    </div>
                {{/unless}}
                <button class="theme-toggle theme-toggle-desktop" type="button" aria-label="Toggle dark mode" aria-pressed="false" data-theme-toggle>
                    <span class="toggle-track" aria-hidden="true">
                        <span class="toggle-sun">{{> "icons/sun"}}</span>
                        <span class="toggle-moon">{{> "icons/moon"}}</span>
                        <span class="toggle-thumb"></span>
                    </span>
                </button>
            </div>
        </div>
    </header>

    <div class="site-content">
        {{{body}}}
    </div>

    <footer class="gh-foot{{#unless @site.secondary_navigation}} no-menu{{/unless}} gh-outer">
        <div class="gh-foot-inner gh-inner">
            <div class="gh-copyright">
                {{@site.title}} © {{date format="YYYY"}}
            </div>
            <div class="gh-foot-center">
                <div class="gh-social-links">
                    {{#social_accounts @site}}
                        <a href="{{href}}" target="_blank" rel="noopener" aria-label="{{name}}">
                            {{#> (concat "icons/" type)}}
                                {{!-- Fallback when no per-platform icon partial exists --}}
                                <span>{{name}}</span>
                            {{/undefined}}
                        </a>
                    {{/social_accounts}}
                </div>
                {{#if @site.secondary_navigation}}
                    <nav class="gh-foot-menu">
                        {{navigation type="secondary"}}
                    </nav>
                {{/if}}
            </div>
            <div class="gh-powered-by">
                {{{t "Powered by {ghostlink}" ghostlink="<a href=\"https://ghost.org/\" target=\"_blank\" rel=\"noopener\">Ghost</a>"}}}
            </div>
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}" defer></script>
{{#is "post, page"}}
    <script src="{{asset "built/post.min.js"}}" defer></script>
{{/is}}

{{ghost_foot}}

</body>
</html>
