{{!< default}}

<div class="content-area">
<main class="site-main">

    {{#post}}

    <article class="{{post_class}}{{#unless feature_image}} no-image{{/unless}} single-post">

        {{#if feature_image}}
            <header class="article-hero">
                <img
                    class="article-hero-image"
                    srcset="{{img_url feature_image size="s"}} 400w,
                            {{img_url feature_image size="m"}} 750w,
                            {{img_url feature_image size="l"}} 960w,
                            {{img_url feature_image size="xl"}} 1140w,
                            {{img_url feature_image size="xxl"}} 1920w"
                    sizes="100vw"
                    src="{{img_url feature_image size="xxl"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                >
                <div class="article-hero-content gh-outer">
                    <div class="gh-inner">
                        <div class="post-meta">
                            <span class="post-meta-item post-meta-date">
                                <time datetime="{{date format="YYYY-MM-DD"}}">{{> "date"}}</time>
                            </span>
                            {{#if reading_time}}
                                <span class="post-meta-item post-meta-length">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                            {{/if}}
                            {{#if @site.comments_enabled}}
                                {{comment_count class="post-meta-item"}}
                            {{/if}}
                            {{#primary_tag}}
                                <span class="post-meta-item post-meta-tags"><a class="post-tag post-tag-{{slug}}" href="{{url}}" title="{{name}}">{{name}}</a></span>
                            {{/primary_tag}}
                        </div>
                        <h1 class="post-title">{{title}}</h1>
                    </div>
                </div>
            </header>
        {{else}}
            <header class="article-header gh-canvas">
                <div class="post-meta">
                    <span class="post-meta-item post-meta-date">
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{> "date"}}</time>
                    </span>
                    {{#if reading_time}}
                        <span class="post-meta-item post-meta-length">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                    {{/if}}
                    {{#if @site.comments_enabled}}
                        {{comment_count class="post-meta-item"}}
                    {{/if}}
                    {{#primary_tag}}
                        <span class="post-meta-item post-meta-tags"><a class="post-tag post-tag-{{slug}}" href="{{url}}" title="{{name}}">{{name}}</a></span>
                    {{/primary_tag}}
                </div>
                <h1 class="post-title">{{title}}</h1>
            </header>
        {{/if}}

        <div class="gh-content gh-canvas">
            {{content}}
        </div>

        <div class="gh-canvas">
            <div class="gh-meta-share">
                <a href="#/share" class="gh-button-share">{{t "Share"}} {{> "icons/share"}}</a>
            </div>
        </div>

        {{#if @custom.show_author}}
            {{> "author-box"}}
        {{/if}}

    </article>

    {{#if comments}}
        <section class="gh-comments gh-canvas">
            <h3 class="related-title">{{t "Comments"}} ({{comment_count empty="0" singular="" plural=""}})</h3>
            {{comments title="" count=false}}
        </section>
    {{/if}}

    {{#if @custom.show_related_posts}}
        {{> "related"}}
    {{/if}}

    {{/post}}

</main>
</div>
